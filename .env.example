# ============================================
# Musharaka Financial Services - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================

# --------------------------------------------
# Supabase Configuration (with Custom Prefix)
# --------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API

MUSHARAKA_SUPABASE_URL=https://your-project-id.supabase.co
MUSHARAKA_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# Blob Storage Configuration (Optional)
# --------------------------------------------
# If using Vercel Blob or other blob storage services

# MUSHARAKA_BLOB_READ_WRITE_TOKEN=your_blob_token_here
# MUSHARAKA_BLOB_STORE_URL=https://your-store.blob.vercel-storage.com
# MUSHARAKA_BLOB_STORE_ID=store_id_here

# --------------------------------------------
# Telegram Bot Configuration (for form submissions)
# --------------------------------------------

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --------------------------------------------
# Application Settings
# --------------------------------------------

NODE_ENV=development
PORT=3000

# --------------------------------------------
# Legacy Support (Deprecated - Use MUSHARAKA_ prefix instead)
# --------------------------------------------
# These are kept for backward compatibility but will be removed in future versions

# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
