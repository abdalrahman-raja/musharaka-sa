# ============================================
# Musharaka Financial Services - Environment Configuration Example
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================

# --------------------------------------------
# Supabase Configuration (with MUSHARAKA_ prefix)
# --------------------------------------------
# Get these from: https://supabase.com/dashboard/project/awuqpxwfpsasvuulexdk/settings/api

MUSHARAKA_SUPABASE_URL=https://awuqpxwfpsasvuulexdk.supabase.co
MUSHARAKA_SUPABASE_ANON_KEY=your_anon_key_here
MUSHARAKA_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Connection String (optional, for database tools)
MUSHARAKA_DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.awuqpxwfpsasvuulexdk.supabase.co:5432/postgres

# --------------------------------------------
# Telegram Bot Configuration (for form submissions)
# --------------------------------------------
# Get these from @BotFather on Telegram

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --------------------------------------------
# Application Settings
# --------------------------------------------

NODE_ENV=development
PORT=3000

# --------------------------------------------
# Backend API Settings (if running separately)
# --------------------------------------------

BACKEND_PORT=3001
JWT_SECRET=change_this_to_a_secure_random_string_in_production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,null
